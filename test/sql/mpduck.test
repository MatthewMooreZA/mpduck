# name: test/sql/mpduck.test
# description: test mpduck extension
# group: [sql]

# Require statement will ensure this test is run with this extension loaded
require mpduck

# Confirm read_mpfile function is registered
statement error
SELECT * FROM read_mpfile();
----

# Schema row maps types: T{n}=VARCHAR, S=SMALLINT, N=DOUBLE, I=INTEGER
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM read_mpfile('test/data/schema.rpt'))
ORDER BY column_name;
----
AGE	SMALLINT
CODE	VARCHAR
COUNT	INTEGER
NAME	VARCHAR
SCORE	DOUBLE

# Glob: schemas are merged across all matching files, widening types where they differ.
# glob_a:  NAME=VARCHAR, AGE=SMALLINT, SCORE=DOUBLE,  CODE=VARCHAR
# glob_a2: NAME=VARCHAR, SALARY=DOUBLE, DEPT=VARCHAR
# glob_b:  NAME=VARCHAR, AGE=INTEGER,  SCORE=INTEGER, CODE=VARCHAR
# glob_b2: NAME=VARCHAR, RATING=DOUBLE, GRADE=VARCHAR
# merged:  NAME=VARCHAR, AGE=INTEGER, SCORE=DOUBLE, CODE=VARCHAR,
#          SALARY=DOUBLE, DEPT=VARCHAR, RATING=DOUBLE, GRADE=VARCHAR
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM read_mpfile('test/data/glob_*.rpt'))
ORDER BY column_name;
----
AGE	INTEGER
CODE	VARCHAR
DEPT	VARCHAR
GRADE	VARCHAR
NAME	VARCHAR
RATING	DOUBLE
SALARY	DOUBLE
SCORE	DOUBLE

# Rows starting with '&' are ignored (not treated as schema rows)
query TI rowsort
SELECT NAME, AGE FROM read_mpfile('test/data/ampersand_row.rpt');
----
Alice	30
Bob	25

# Header row indicator with trailing digit (!1) is treated the same as (!)
query IIR rowsort
SELECT NAME, AGE, SCORE FROM read_mpfile('test/data/header_variation.rpt');
----
Alice	30	98.5
Bob	25	72.0

# Footer content after the last data row is silently ignored — no error, no extra rows
query TI rowsort
SELECT NAME, AGE FROM read_mpfile('test/data/footer.rpt');
----
Alice	30
Bob	25

# Files with pre-data metadata lines (Output_Format, NUMLINES) are parsed correctly.
# These lines appear before any '!' or '*' row and must be skipped, not treated as footer.
query TRI rowsort
SELECT NAME, LENGTH_M, DISCOVERED FROM read_mpfile('test/data/leading_metadata.rpt');
----
Brachiosaurus	26.0	1900
T_Rex	12.3	1902
Velociraptor	1.8	1924

# Confirm data round-trips correctly: glob_*.rpt now covers all four glob files;
# NAME is the column present in every file.
query T rowsort
SELECT NAME FROM read_mpfile('test/data/glob_*.rpt');
----
Alice
Bob
Charlie
Diana

# List overload: explicit list of files — schemas merged, rows combined
query IIIR rowsort
SELECT NAME, AGE, CODE, SCORE FROM read_mpfile(['test/data/glob_a.rpt', 'test/data/glob_b.rpt']);
----
Alice	30	ABC	98.5
Bob	25	XYZ	72.0

# List overload: single glob entry expands to all matching files; NAME is present in all four
query T rowsort
SELECT NAME FROM read_mpfile(['test/data/glob_*.rpt']);
----
Alice
Bob
Charlie
Diana

# List overload: schema merging across list entries (AGE widened SMALLINT→INTEGER, SCORE widened →DOUBLE)
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM read_mpfile(['test/data/glob_a.rpt', 'test/data/glob_b.rpt']))
ORDER BY column_name;
----
AGE	INTEGER
CODE	VARCHAR
NAME	VARCHAR
SCORE	DOUBLE

# List overload: two glob patterns each matching multiple files.
# glob_a*.rpt → glob_a.rpt (NAME,AGE,SCORE,CODE) + glob_a2.rpt (NAME,SALARY,DEPT)
# glob_b*.rpt → glob_b.rpt (NAME,AGE,SCORE,CODE) + glob_b2.rpt (NAME,RATING,GRADE)
# NAME is the only column present in all four files; selecting it gives a clean equality check.
# Results must equal the equivalent explicit file list.
query T rowsort
SELECT NAME FROM read_mpfile(['test/data/glob_a*.rpt', 'test/data/glob_b*.rpt']);
----
Alice
Bob
Charlie
Diana

query T rowsort
SELECT NAME FROM read_mpfile(['test/data/glob_a.rpt', 'test/data/glob_a2.rpt', 'test/data/glob_b.rpt', 'test/data/glob_b2.rpt']);
----
Alice
Bob
Charlie
Diana

# List overload: two glob patterns (each matching multiple files) plus one explicit file.
# footer.rpt contributes Alice and Bob; all six rows are union'd via union_by_name.
# Results must equal the equivalent explicit file list.
query T rowsort
SELECT NAME FROM read_mpfile(['test/data/glob_a*.rpt', 'test/data/glob_b*.rpt', 'test/data/footer.rpt']);
----
Alice
Alice
Bob
Bob
Charlie
Diana

query T rowsort
SELECT NAME FROM read_mpfile(['test/data/glob_a.rpt', 'test/data/glob_a2.rpt', 'test/data/glob_b.rpt', 'test/data/glob_b2.rpt', 'test/data/footer.rpt']);
----
Alice
Alice
Bob
Bob
Charlie
Diana

# No VARIABLE_TYPES row — types are inferred by read_csv_auto from the data values.
# One column of each inferred type: VARCHAR, BIGINT, DOUBLE, BOOLEAN, DATE.
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM read_mpfile('test/data/no_variable_types.rpt'))
ORDER BY column_name;
----
ACTIVE	BOOLEAN
AGE	BIGINT
DOB	DATE
NAME	VARCHAR
SCORE	DOUBLE

query TIRTT rowsort
SELECT NAME, AGE, SCORE, ACTIVE, DOB FROM read_mpfile('test/data/no_variable_types.rpt');
----
Alice	30	98.5	true	1990-01-15
Bob	25	72.3	false	1995-06-20

# Mixed indicator variants across files: '!' and '!1' both normalise to the same indicator
# column '!', so schema merging produces exactly one '!' column and the EXCLUDE step works.
query TIT rowsort
SELECT NAME, AGE, CITY FROM read_mpfile(['test/data/mixed_indicator_a.rpt', 'test/data/mixed_indicator_b.rpt']);
----
Alice	30	London
Bob	25	Paris

# The merged schema must contain no '!' column — only the data columns.
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM read_mpfile(['test/data/mixed_indicator_a.rpt', 'test/data/mixed_indicator_b.rpt']))
ORDER BY column_name;
----
AGE	SMALLINT
CITY	VARCHAR
NAME	VARCHAR

# No footer: file ends immediately after the last data row (no trailing newline or footer lines).
query TI rowsort
SELECT NAME, AGE FROM read_mpfile('test/data/no_footer.rpt');
----
Alice	30
Bob	25

# Large footer (>4 KB): the initial 4 KB chunk is entirely footer; the doubling loop must
# expand the window until it finds the last '*' row.
query TI rowsort
SELECT NAME, AGE FROM read_mpfile('test/data/large_footer.rpt');
----
Alice	30
Bob	25

# write_mpfile: round-trip all four VARIABLE_TYPES codes (T→VARCHAR, S→SMALLINT, N→DOUBLE, I→INTEGER)
statement ok
COPY (
  SELECT 'Alice' AS NAME, CAST(30 AS SMALLINT) AS AGE, 98.5 AS SCORE, 'ABC123' AS CODE, 7 AS COUNT
) TO '__TEST_DIR__/write_basic.rpt' (FORMAT mpfile);

query TIRTI rowsort
SELECT NAME, AGE, SCORE, CODE, COUNT FROM read_mpfile('__TEST_DIR__/write_basic.rpt');
----
Alice	30	98.5	ABC123	7

# write_mpfile: schema types are preserved via the VARIABLE_TYPES row
query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM read_mpfile('__TEST_DIR__/write_basic.rpt'))
ORDER BY column_name;
----
AGE	SMALLINT
CODE	VARCHAR
COUNT	INTEGER
NAME	VARCHAR
SCORE	DOUBLE

# write_mpfile: multiple data rows
statement ok
COPY (
  SELECT * FROM (VALUES
    ('Alice', CAST(30 AS SMALLINT), 98.5),
    ('Bob',   CAST(25 AS SMALLINT), 72.0)
  ) t(NAME, AGE, SCORE)
) TO '__TEST_DIR__/write_multi.rpt' (FORMAT mpfile);

query TIR rowsort
SELECT NAME, AGE, SCORE FROM read_mpfile('__TEST_DIR__/write_multi.rpt');
----
Alice	30	98.5
Bob	25	72.0

# write_mpfile: string values containing commas and double-quotes round-trip correctly
statement ok
COPY (
  SELECT 'value,with,commas' AS A, 'value"with"quotes' AS B
) TO '__TEST_DIR__/write_special.rpt' (FORMAT mpfile);

query TT rowsort
SELECT A, B FROM read_mpfile('__TEST_DIR__/write_special.rpt');
----
value,with,commas	value"with"quotes

# Round-trip: read an existing sample file, write it back, confirm data and types are preserved.
# schema.rpt exercises all four mpfile type codes: T (VARCHAR), S (SMALLINT), N (DOUBLE), I (INTEGER).
statement ok
COPY (SELECT * FROM read_mpfile('test/data/schema.rpt'))
  TO '__TEST_DIR__/roundtrip.rpt' (FORMAT mpfile);

query TIRTI rowsort
SELECT NAME, AGE, SCORE, CODE, COUNT FROM read_mpfile('__TEST_DIR__/roundtrip.rpt');
----
Alice	30	98.5	ABC123	7
Bob	25	72.0	XYZ999	3

query II
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM read_mpfile('__TEST_DIR__/roundtrip.rpt'))
ORDER BY column_name;
----
AGE	SMALLINT
CODE	VARCHAR
COUNT	INTEGER
NAME	VARCHAR
SCORE	DOUBLE

# write_mpfile: FORMAT is optional — .rpt extension is auto-detected
statement ok
COPY (
  SELECT 'Alice' AS NAME, CAST(30 AS SMALLINT) AS AGE
) TO '__TEST_DIR__/autodetect.rpt';

query TI rowsort
SELECT NAME, AGE FROM read_mpfile('__TEST_DIR__/autodetect.rpt');
----
Alice	30

# write_mpfile: FORMAT is optional — .prn extension is auto-detected
statement ok
COPY (
  SELECT 'Bob' AS NAME, CAST(25 AS SMALLINT) AS AGE
) TO '__TEST_DIR__/autodetect.prn';

query TI rowsort
SELECT NAME, AGE FROM read_mpfile('__TEST_DIR__/autodetect.prn');
----
Bob	25

# write_mpfile: FORMAT is optional — .fac extension is auto-detected
statement ok
COPY (
  SELECT 'Carol' AS NAME, CAST(40 AS SMALLINT) AS AGE
) TO '__TEST_DIR__/autodetect.fac';

query TI rowsort
SELECT NAME, AGE FROM read_mpfile('__TEST_DIR__/autodetect.fac');
----
Carol	40

# write_mpfile: KV_METADATA writes metadata rows before VARIABLE_TYPES; data round-trips cleanly
statement ok
COPY (
  SELECT 'Alice' AS NAME, CAST(30 AS SMALLINT) AS AGE
) TO '__TEST_DIR__/write_meta.rpt' (FORMAT mpfile, KV_METADATA {answer: '42', note: 'hello world'});

query TI rowsort
SELECT NAME, AGE FROM read_mpfile('__TEST_DIR__/write_meta.rpt');
----
Alice	30

# write_mpfile: KV_METADATA with values containing commas round-trips cleanly
statement ok
COPY (
  SELECT 'Bob' AS NAME, CAST(25 AS SMALLINT) AS AGE
) TO '__TEST_DIR__/write_meta_comma.rpt' (FORMAT mpfile, KV_METADATA {label: 'one,two,three'});

query TI rowsort
SELECT NAME, AGE FROM read_mpfile('__TEST_DIR__/write_meta_comma.rpt');
----
Bob	25

# write_mpfile: INCLUDE_TYPES=true (explicit) still writes VARIABLE_TYPES row; data round-trips cleanly
statement ok
COPY (
  SELECT 'Dave' AS NAME, CAST(35 AS SMALLINT) AS AGE
) TO '__TEST_DIR__/write_include_types_true.rpt' (FORMAT mpfile, INCLUDE_TYPES true);

query TI rowsort
SELECT NAME, AGE FROM read_mpfile('__TEST_DIR__/write_include_types_true.rpt');
----
Dave	35

# write_mpfile: INCLUDE_TYPES=false omits the VARIABLE_TYPES row; header and data rows still present
statement ok
COPY (
  SELECT 'Eve' AS NAME, CAST(28 AS SMALLINT) AS AGE
) TO '__TEST_DIR__/write_include_types_false.rpt' (FORMAT mpfile, INCLUDE_TYPES false);

# Confirm the file content starts with the header row (no VARIABLE_TYPES line)
query I
SELECT starts_with(content, '!') FROM read_text('__TEST_DIR__/write_include_types_false.rpt');
----
1

# write_mpfile: KV_METADATA is optional — omitting it still produces a valid file
statement ok
COPY (
  SELECT 'Carol' AS NAME, CAST(40 AS SMALLINT) AS AGE
) TO '__TEST_DIR__/write_no_meta.rpt' (FORMAT mpfile);

query TI rowsort
SELECT NAME, AGE FROM read_mpfile('__TEST_DIR__/write_no_meta.rpt');
----
Carol	40

# read_mpfile: .fac file is parsed as an mpfile
query TIRTI rowsort
SELECT NAME, AGE, SCORE, CODE, COUNT FROM read_mpfile('test/data/schema.fac');
----
Alice	30	98.5	ABC123	7
Bob	25	72.0	XYZ999	3

# well-formed mpfile with CRLF line endings (standard case)
query TIR rowsort
SELECT NAME, AGE, SCORE FROM read_mpfile('test/data/crlf.rpt');
----
Alice	30	98.5
Bob	25	72.0

# CRLF: schema types are correctly inferred from VARIABLE_TYPES row
query II rowsort
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM read_mpfile('test/data/crlf.rpt'))
ORDER BY column_name;
----
AGE	SMALLINT
NAME	VARCHAR
SCORE	DOUBLE

# large file with CRLF endings (>1 MB data section) — exercises the FindDataEnd fix
query I
SELECT COUNT(*) FROM read_mpfile('test/data/large_crlf.rpt');
----
56000

# pure LF line endings: backward-compatible with non-standard files
query TIR rowsort
SELECT NAME, AGE, SCORE FROM read_mpfile('test/data/lf.rpt');
----
Alice	30	98.5
Bob	25	72.0

# pure LF: schema types still inferred correctly
query II rowsort
SELECT column_name, column_type
FROM (DESCRIBE SELECT * FROM read_mpfile('test/data/lf.rpt'))
ORDER BY column_name;
----
AGE	SMALLINT
NAME	VARCHAR
SCORE	DOUBLE
